<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback config with OpenTelemetry appender.
  Bridges all log events to the OTLP pipeline so they reach Loki via the LGTM stack.
  The CONSOLE appender preserves normal stdout logging.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- OpenTelemetry appender: forwards log events to the OTLP SDK -->
    <appender name="OTEL" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
        <captureExperimentalAttributes>true</captureExperimentalAttributes>
        <captureMdcAttributes>*</captureMdcAttributes>
    </appender>

    <!--
      Suppress the "Serializing PageImpl instances as-is is not supported" warning.
      Migrating to VIA_DTO would require changing the JSON shape from flat (totalElements,
      totalPages at root) to nested (page.totalElements, page.totalPages) — a breaking change
      for both the frontend Page<T> interface and integration tests. Suppressed intentionally
      until a dedicated migration is planned.
    -->
    <logger name="org.springframework.data.web" level="ERROR"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="OTEL"/>
    </root>
</configuration>
